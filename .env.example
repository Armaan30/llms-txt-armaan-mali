# Postgres connection string. Any Postgres works; Neon's free tier is the
# zero-setup option (https://neon.tech) and is what the deployed app uses.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Anthropic API key — powers the summary + section organization. Optional:
# without it, files are generated from URL-structure heuristics alone.
ANTHROPIC_API_KEY=""

# Model for the organization step (defaults to claude-opus-4-8).
# ANTHROPIC_MODEL="claude-opus-4-8"

# Shared secret protecting the monitoring endpoint (/api/cron/check).
# Vercel sends it automatically as "Authorization: Bearer <CRON_SECRET>".
CRON_SECRET=""
